{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "strict": false,
    "allowJs": true
  },
  "include": ["server.ts", "src/server/**/*", "src/lib/**/*"]
}